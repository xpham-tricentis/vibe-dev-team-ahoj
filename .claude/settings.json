{
  "model": "claude-sonnet-4-6",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\n%s\\n\\n%s\\n%s\\n%s\\n\\n%s\\n\\n' '👋 Welcome — this seed runs the business-intake → spec-writer → orchestrator pipeline.' 'Quick start:' '  /business-intake   (recommended — plain-language interview, drafts proposal + spec for you)' '  /spec-writer       (alternative — section-by-section spec authoring)' 'Type one of those to begin.'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",

      "Skill(spec-writer)",
      "Skill(orchestrator)",
      "Skill(validate)",
      "Skill(jira-ticket)",
      "Skill(readme-skill)",
      "Skill(architecture-pattern-selector)",
      "Skill(business-intake)",
      "Skill(usage-report)",

      "Bash(docker *)",

      "Bash(uv *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pytest *)",
      "Bash(mypy *)",
      "Bash(ruff *)",
      "Bash(uvicorn *)",

      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(vite *)",
      "Bash(tsc *)",
      "Bash(vitest *)",
      "Bash(eslint *)",

      "Bash(mkdir *)",
      "Bash(mkdir * && mkdir *)",
      "Bash(mkdir * && mkdir * && mkdir *)",
      "Bash(touch *)",
      "Bash(cat *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(ls *)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(xargs *)",

      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show *)",
      "Bash(git -C * status*)",
      "Bash(git -C * branch*)",
      "Bash(git -C * diff*)",
      "Bash(git -C * log*)",

      "Bash(git stash *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit -m \"self-update:*)",
      "Bash(git commit -m 'self-update:*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME/*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)"
    ]
  }
}
